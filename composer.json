{
    "name": "dubmilli/payjp",
    "description": "Payjp plugin for CakePHP",
    "type": "cakephp-plugin",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "cakephp/cakephp": "5.2.*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.1"
    },
    "autoload": {
        "psr-4": {
            "Payjp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Payjp\\Test\\": "tests/",
            "Cake\\Test\\": "vendor/cakephp/cakephp/tests/"
        }
    }
}
